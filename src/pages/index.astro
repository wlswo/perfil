---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const showcases = [
  {
    id: 'search',
    title: '원하는 책을 찾아보세요',
    description:
      'ISBN 데이터베이스에서 제목, 저자, 출판사로 검색해 내 책장에 담을 수 있어요. 직접 입력하지 않아도 표지와 정보가 자동으로 채워집니다.',
  },
  {
    id: 'ticket',
    title: '완독은 곧 한 장의 티켓',
    description:
      '책을 끝까지 읽으면 그 순간을 기념할 빈티지 티켓이 발급돼요. 별점, 메모, 읽은 기간이 함께 새겨집니다.',
  },
  {
    id: 'rating',
    title: '내 마음을 단정하게 남기는 곳',
    description:
      '별점은 눈금으로, 감상은 짧은 메모로. 가볍지만 진심이 담기는 기록 방식입니다.',
  },
  {
    id: 'card',
    title: '한 장의 카드로 공유',
    description:
      '내가 읽은 책을 한 장의 독서 카드로 만들어 갤러리에 저장하고 친구들과 공유할 수 있어요.',
  },
  {
    id: 'folder',
    title: '내 책장은 내 마음대로',
    description:
      '장르별, 시리즈별, 분위기별 — 폴더로 묶어 나만의 방식대로 책장을 정리해보세요.',
  },
];

// 카테고리 캐릭터 — 책 카테고리(BookCategory) 기준 한국어 라벨
const friends: { file: string; label: string }[] = [
  { file: 'literature_icon.webp', label: '문학' },
  { file: 'essay_icon.webp', label: '에세이' },
  { file: 'humanities_icon.webp', label: '인문학' },
  { file: 'history_icon.webp', label: '역사' },
  { file: 'science_icon.webp', label: '과학' },
  { file: 'social_science_icon.webp', label: '사회과학' },
  { file: 'business_icon.webp', label: '경제경영' },
  { file: 'self_development_icon.webp', label: '자기계발' },
  { file: 'biography_icon.webp', label: '인물' },
  { file: 'art_icon.webp', label: '예술' },
  { file: 'music_icon.webp', label: '음악' },
  { file: 'movie_icon.webp', label: '영화' },
  { file: 'travel_icon.webp', label: '여행' },
  { file: 'cooking_icon.webp', label: '요리' },
  { file: 'beauty_icon.webp', label: '뷰티' },
  { file: 'health_icon.webp', label: '건강' },
  { file: 'medicine_icon.webp', label: '의학' },
  { file: 'sports_icon.webp', label: '스포츠' },
  { file: 'hobby_icon.webp', label: '취미' },
  { file: 'pets_icon.webp', label: '반려동물' },
  { file: 'home_icon.webp', label: '가정' },
  { file: 'family_icon.webp', label: '가족관계' },
  { file: 'kids_icon.webp', label: '유아' },
  { file: 'teen_icon.webp', label: '청소년' },
  { file: 'religion_icon.webp', label: '종교' },
  { file: 'comics_icon.webp', label: '만화' },
  { file: 'genre_fiction_icon.webp', label: '장르소설' },
  { file: 'magazine_icon.webp', label: '잡지' },
  { file: 'collection_icon.webp', label: '전집' },
  { file: 'audiobook_icon.webp', label: '오디오북' },
  { file: 'foreign_language_icon.webp', label: '외국어' },
  { file: 'foreign_book_icon.webp', label: '해외도서' },
  { file: 'linguistics_icon.webp', label: '언어학' },
  { file: 'dictionary_icon.webp', label: '사전' },
  { file: 'computer_icon.webp', label: '컴퓨터' },
  { file: 'architecture_icon.webp', label: '건축' },
  { file: 'law_icon.webp', label: '법률' },
  { file: 'textbook_icon.webp', label: '교재' },
  { file: 'gift_icon.webp', label: '선물' },
  { file: 'etc_icon.webp', label: '기타' },
];

// 두 줄로 분배
const friendsRowA = friends.filter((_, i) => i % 2 === 0);
const friendsRowB = friends.filter((_, i) => i % 2 === 1);
---

<Layout
  title="퍼필 — 나만의 독서 컬렉션"
  description="읽은 책이 차곡차곡 쌓이는 따뜻한 독서 기록 앱"
>
  <section class="hero">
    <div class="mascot-wrap" aria-hidden="true">
      <img
        src={`${base}/perfil_mascot.png`}
        alt=""
        class="mascot"
        width="180"
        height="158"
        draggable="false"
      />
    </div>

    <h1>읽은 책이<br />차곡차곡 쌓이는 곳</h1>
    <p class="subtitle">
      퍼필은 나만의 독서 컬렉션을 만드는 따뜻한 기록 앱입니다.
    </p>

    <div class="cta-buttons">
      <a href="#" class="store-button" aria-label="App Store에서 다운로드">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M17.05 20.28c-.98.95-2.05.86-3.08.39-1.09-.49-2.08-.5-3.24 0-1.44.61-2.2.43-3.06-.39C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.79 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
        </svg>
        App Store
      </a>
      <a href="#" class="store-button" aria-label="Google Play에서 다운로드">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.039 12l2.66-2.491zm-13.834-9L16.801 7.84l-2.302 2.303L5.864.16z" />
        </svg>
        Google Play
      </a>
    </div>
    <p class="cta-note">곧 출시 예정</p>
  </section>

  <section class="showcase-section">
    {showcases.map((s, idx) => (
      <article class={`showcase reveal ${idx % 2 === 1 ? 'showcase--reverse' : ''}`}>
        <div class="showcase-mockup">
          {s.id === 'search' && (
            <div class="phone-frame">
              <div class="phone-screen">
                <div class="mock-tab-row"><span>홈</span><span>독서</span><span class="mock-tab-active">검색</span></div>
                <div class="mock-search">데미안</div>
                <div class="mock-book">
                  <div class="mock-cover" style="background:linear-gradient(135deg,#9bb5d6,#5d7ea6);"></div>
                  <div class="mock-meta"><strong>데미안</strong><span>헤르만 헤세</span></div>
                </div>
                <div class="mock-book">
                  <div class="mock-cover" style="background:linear-gradient(135deg,#d6c4a3,#a48d6c);"></div>
                  <div class="mock-meta"><strong>달과 6펜스</strong><span>서머싯 몸</span></div>
                </div>
              </div>
            </div>
          )}

          {s.id === 'ticket' && (
            <div class="phone-frame">
              <div class="phone-screen phone-screen--center">
                <div class="mock-ticket">
                  <div class="mock-ticket-row"><span>NO.</span><span>0023</span></div>
                  <div class="mock-ticket-perforation"></div>
                  <div class="mock-ticket-mid">
                    <div class="mock-ticket-title">데미안</div>
                    <div class="mock-ticket-stars">★★★★★</div>
                  </div>
                  <div class="mock-ticket-perforation"></div>
                  <div class="mock-ticket-bottom">PERFIL · ADMIT ONE</div>
                </div>
              </div>
            </div>
          )}

          {s.id === 'rating' && (
            <div class="phone-frame">
              <div class="phone-screen">
                <div class="mock-detail-title">데미안</div>
                <div class="mock-stars-large">
                  <span>★</span><span>★</span><span>★</span><span>★</span><span class="dim">★</span>
                </div>
                <div class="mock-detail-label">메모</div>
                <div class="mock-memo">
                  데미안과 싱클레어의 대화는 늘 마음을 흔든다.
                </div>
              </div>
            </div>
          )}

          {s.id === 'card' && (
            <div class="phone-frame">
              <div class="phone-screen phone-screen--center">
                <div class="mock-card">
                  <div class="mock-card-cover" style="background:linear-gradient(135deg,#9bb5d6,#5d7ea6);"></div>
                  <div class="mock-card-quote">"새는 알을 깨고 나온다."</div>
                  <div class="mock-card-bottom">
                    <span>데미안</span>
                    <span>★ 4.5</span>
                  </div>
                  <div class="mock-card-brand">perfil</div>
                </div>
              </div>
            </div>
          )}

          {s.id === 'folder' && (
            <div class="phone-frame">
              <div class="phone-screen">
                <div class="mock-folder-row">
                  <div class="mock-folder">
                    <div class="mock-folder-tab"></div>
                    <div class="mock-folder-body">소설</div>
                  </div>
                  <div class="mock-folder">
                    <div class="mock-folder-tab"></div>
                    <div class="mock-folder-body">에세이</div>
                  </div>
                </div>
                <div class="mock-grid">
                  <div class="mock-mini-cover" style="background:#9bb5d6;"></div>
                  <div class="mock-mini-cover" style="background:#d6c4a3;"></div>
                  <div class="mock-mini-cover" style="background:#c5a0a0;"></div>
                  <div class="mock-mini-cover" style="background:#a8b89a;"></div>
                </div>
              </div>
            </div>
          )}
        </div>

        <div class="showcase-text">
          <h3>{s.title}</h3>
          <p>{s.description}</p>
        </div>
      </article>
    ))}
  </section>

  <section class="friends-section reveal">
    <div class="friends-header">
      <h2>40명의 친구들이 함께해요</h2>
      <p>
        책 카테고리에 따라 서로 다른 친구가 완독 티켓의 주인공이 됩니다.
        <br />어떤 친구가 내 티켓에 등장할지 기대해보세요.
      </p>
    </div>

    <div class="marquee" aria-hidden="true">
      <div class="marquee-track marquee-track--left">
        {[...friendsRowA, ...friendsRowA].map((f) => (
          <div class="friend">
            <img
              src={`${base}/characters/${f.file}`}
              alt=""
              loading="lazy"
              width="72"
              height="72"
            />
            <span class="friend-label">{f.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="marquee" aria-hidden="true">
      <div class="marquee-track marquee-track--right">
        {[...friendsRowB, ...friendsRowB].map((f) => (
          <div class="friend">
            <img
              src={`${base}/characters/${f.file}`}
              alt=""
              loading="lazy"
              width="72"
              height="72"
            />
            <span class="friend-label">{f.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="friends-counter">
      <span class="counter-num">40</span>
      <span class="counter-text">CHARACTERS</span>
    </div>
  </section>

  <section class="legal-links reveal">
    <h2>법적 고지</h2>
    <ul class="legal-list">
      <li>
        <a href={`${base}/terms`}>
          <span>서비스 이용약관</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </li>
      <li>
        <a href={`${base}/privacy`}>
          <span>개인정보 처리방침</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </li>
    </ul>
  </section>
</Layout>

<script>
  // 스크롤 진입 시 reveal
  const supportsIO = 'IntersectionObserver' in window;
  const els = document.querySelectorAll<HTMLElement>('.reveal');

  if (!supportsIO) {
    els.forEach((el) => el.classList.add('visible'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    els.forEach((el) => io.observe(el));
  }
</script>

<style>
  /* ─── Hero ─── */
  .hero {
    text-align: center;
    padding: 24px 0 56px;
  }

  /* ─── Mascot (idle bob + hover wiggle) ─── */
  .mascot-wrap {
    margin: 0 auto 12px;
    display: flex;
    justify-content: center;
  }
  .mascot {
    display: block;
    width: 180px;
    height: auto;
    transform-origin: 50% 90%;
    animation: bob 4s ease-in-out infinite;
    user-select: none;
  }
  .mascot-wrap:hover .mascot {
    animation: wiggle 0.6s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-6px) rotate(2deg); }
  }
  @keyframes wiggle {
    0%, 100% { transform: rotate(-8deg); }
    50% { transform: rotate(8deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mascot,
    .mascot-wrap:hover .mascot {
      animation: none;
    }
  }

  .hero h1 {
    font-size: 44px;
    margin-bottom: 18px;
    letter-spacing: -1.2px;
  }
  .hero .subtitle {
    font-size: 18px;
    opacity: 0.7;
    margin-bottom: 36px;
  }

  /* ─── CTA ─── */
  .cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .store-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: var(--ink);
    color: var(--paper) !important;
    font-weight: 700;
    border: 1.5px solid var(--ink);
    box-shadow: 4px 4px 0 var(--ink);
    transition:
      transform 0.1s ease,
      box-shadow 0.1s ease;
  }
  .store-button:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--ink);
    color: var(--paper) !important;
  }
  .cta-note {
    font-size: 13px;
    opacity: 0.5;
  }

  /* ─── Showcase ─── */
  .showcase-section {
    margin-top: 80px;
    display: flex;
    flex-direction: column;
    gap: 100px;
  }
  .showcase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .showcase--reverse {
    direction: rtl;
  }
  .showcase--reverse > * {
    direction: ltr;
  }
  .showcase-mockup {
    display: flex;
    justify-content: center;
  }
  .showcase-text h3 {
    font-size: 24px;
    margin-bottom: 14px;
    line-height: 1.35;
    letter-spacing: -0.6px;
  }
  .showcase-text p {
    font-size: 16px;
    opacity: 0.78;
    line-height: 1.75;
  }

  /* ─── Phone frame (단축 버전) ─── */
  .phone-frame {
    width: 240px;
    aspect-ratio: 9 / 13;
    background: var(--ink);
    border-radius: 26px;
    padding: 8px;
    box-shadow:
      6px 6px 0 var(--ink),
      0 14px 32px rgba(62, 58, 55, 0.13);
  }
  .phone-screen {
    width: 100%;
    height: 100%;
    background: var(--paper);
    border-radius: 18px;
    padding: 14px 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 11px;
    color: var(--ink);
  }
  .phone-screen--center {
    justify-content: center;
  }

  /* ─── Mockup: Search ─── */
  .mock-tab-row {
    display: flex;
    gap: 10px;
    font-size: 10px;
    opacity: 0.55;
    border-bottom: 1px solid rgba(62, 58, 55, 0.15);
    padding-bottom: 6px;
  }
  .mock-tab-active {
    opacity: 1;
    font-weight: 700;
    color: var(--accent);
  }
  .mock-search {
    background: #fff;
    border: 1px solid var(--ink);
    padding: 7px 10px;
    font-size: 11px;
  }
  .mock-book {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid rgba(62, 58, 55, 0.1);
  }
  .mock-cover {
    width: 28px;
    height: 38px;
    flex-shrink: 0;
  }
  .mock-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mock-meta strong {
    font-size: 11px;
    font-weight: 700;
  }
  .mock-meta span {
    font-size: 9px;
    opacity: 0.6;
  }

  /* ─── Mockup: Ticket ─── */
  .mock-ticket {
    background: #fff;
    border: 1.5px solid var(--ink);
    padding: 12px 14px;
    font-family: 'Courier New', monospace;
  }
  .mock-ticket-row {
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    letter-spacing: 0.5px;
  }
  .mock-ticket-perforation {
    border-top: 1.5px dashed var(--ink);
    margin: 8px -14px;
  }
  .mock-ticket-mid {
    text-align: center;
    padding: 4px 0;
  }
  .mock-ticket-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 6px;
    font-family: inherit;
  }
  .mock-ticket-stars {
    font-size: 14px;
    color: var(--accent);
    letter-spacing: 2px;
  }
  .mock-ticket-bottom {
    text-align: center;
    font-size: 9px;
    letter-spacing: 2px;
    opacity: 0.7;
  }

  /* ─── Mockup: Rating ─── */
  .mock-detail-title {
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .mock-stars-large {
    display: flex;
    gap: 6px;
    font-size: 24px;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .mock-stars-large .dim {
    color: rgba(62, 58, 55, 0.2);
  }
  .mock-detail-label {
    font-size: 10px;
    font-weight: 700;
    opacity: 0.55;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .mock-memo {
    background: #fff;
    border: 1px solid var(--ink);
    padding: 8px 10px;
    font-size: 11px;
    line-height: 1.55;
  }

  /* ─── Mockup: Card ─── */
  .mock-card {
    background: #fff;
    border: 1.5px solid var(--ink);
    padding: 12px;
    box-shadow: 3px 3px 0 var(--ink);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mock-card-cover {
    width: 100%;
    height: 80px;
  }
  .mock-card-quote {
    font-size: 11px;
    line-height: 1.5;
    text-align: center;
    font-style: italic;
    opacity: 0.85;
  }
  .mock-card-bottom {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    border-top: 1px solid rgba(62, 58, 55, 0.2);
    padding-top: 6px;
  }
  .mock-card-brand {
    text-align: right;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--accent);
  }

  /* ─── Mockup: Folder ─── */
  .mock-folder-row {
    display: flex;
    gap: 8px;
  }
  .mock-folder {
    flex: 1;
  }
  .mock-folder-tab {
    width: 40%;
    height: 7px;
    background: var(--paper-dim);
    border: 1px solid var(--ink);
    border-bottom: none;
  }
  .mock-folder-body {
    background: #fff;
    border: 1px solid var(--ink);
    padding: 8px;
    font-size: 11px;
    font-weight: 700;
  }
  .mock-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
