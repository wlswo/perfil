---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="퍼필 — 나만의 독서 컬렉션"
  description="읽은 책이 차곡차곡 쌓이는 따뜻한 독서 기록 앱"
>
  <section class="hero">
    <button
      type="button"
      class="mascot-button"
      id="mascot"
      aria-label="퍼필 마스코트 — 클릭하면 한 바퀴 돕니다"
    >
      <img
        src={`${base}/perfil_mascot.png`}
        alt="퍼필 마스코트"
        class="mascot"
        width="180"
        height="158"
        draggable="false"
      />
    </button>

    <h1>읽은 책이<br />차곡차곡 쌓이는 곳</h1>
    <p class="subtitle">
      퍼필은 나만의 독서 컬렉션을 만드는 따뜻한 기록 앱입니다.
    </p>

    <div class="cta-buttons">
      <a href="#" class="store-button" aria-label="App Store에서 다운로드">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M17.05 20.28c-.98.95-2.05.86-3.08.39-1.09-.49-2.08-.5-3.24 0-1.44.61-2.2.43-3.06-.39C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.79 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
        </svg>
        App Store
      </a>
      <a href="#" class="store-button" aria-label="Google Play에서 다운로드">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.039 12l2.66-2.491zm-13.834-9L16.801 7.84l-2.302 2.303L5.864.16z" />
        </svg>
        Google Play
      </a>
    </div>
    <p class="cta-note">곧 출시 예정</p>
  </section>

  <section class="features">
    <h2>주요 기능</h2>
    <ul class="feature-list">
      <li>
        <span class="feature-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 4.5A2.5 2.5 0 014.5 2H8a2 2 0 012 2v16a1 1 0 01-1.5.866A4.5 4.5 0 006 20H4a2 2 0 01-2-2V4.5z" />
            <path d="M22 4.5A2.5 2.5 0 0019.5 2H16a2 2 0 00-2 2v16a1 1 0 001.5.866A4.5 4.5 0 0118 20h2a2 2 0 002-2V4.5z" />
          </svg>
        </span>
        <span class="feature-text">도서 검색과 책장 관리</span>
      </li>
      <li>
        <span class="feature-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 7a2 2 0 012-2h14a2 2 0 012 2v2a2 2 0 100 4v2a2 2 0 01-2 2H5a2 2 0 01-2-2v-2a2 2 0 100-4V7z" />
            <path d="M9 5v2M9 11v2M9 17v2" stroke-dasharray="0.5 2" />
          </svg>
        </span>
        <span class="feature-text">완독 시 발급되는 나만의 티켓</span>
      </li>
      <li>
        <span class="feature-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2.5l2.9 5.88 6.5.94-4.7 4.58 1.1 6.46L12 17.27 6.2 20.36l1.1-6.46-4.7-4.58 6.5-.94L12 2.5z" />
          </svg>
        </span>
        <span class="feature-text">별점과 짧은 메모로 남기는 기록</span>
      </li>
      <li>
        <span class="feature-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <circle cx="9" cy="9" r="1.6" />
            <path d="M3 16.5l5.5-5.5 4.5 4.5L17 11l4 4" />
          </svg>
        </span>
        <span class="feature-text">갤러리에 저장하는 독서 카드</span>
      </li>
      <li>
        <span class="feature-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 6.5A2 2 0 015 4.5h4l2 2.5h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2v-12z" />
          </svg>
        </span>
        <span class="feature-text">폴더로 정리하는 나만의 책장</span>
      </li>
    </ul>
  </section>

  <section class="legal-links">
    <h2>법적 고지</h2>
    <ul class="legal-list">
      <li>
        <a href={`${base}/terms`}>
          <span>서비스 이용약관</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </li>
      <li>
        <a href={`${base}/privacy`}>
          <span>개인정보 처리방침</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </li>
    </ul>
  </section>
</Layout>

<script>
  const mascotButton = document.getElementById('mascot');
  const mascotImg = mascotButton?.querySelector('img');
  if (mascotButton && mascotImg) {
    mascotButton.addEventListener('click', () => {
      if (mascotImg.classList.contains('spin')) return;
      mascotImg.classList.add('spin');
    });
    mascotImg.addEventListener('animationend', (e) => {
      if (e.animationName === 'spin') mascotImg.classList.remove('spin');
    });
  }
</script>

<style>
  /* ─── Hero ─── */
  .hero {
    text-align: center;
    padding: 24px 0 56px;
  }

  /* ─── Mascot ─── */
  .mascot-button {
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    margin: 0 auto 12px;
    display: block;
    outline: none;
  }
  .mascot-button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 8px;
    border-radius: 999px;
  }

  .mascot {
    display: block;
    width: 180px;
    height: auto;
    transform-origin: 50% 90%;
    animation: bob 4s ease-in-out infinite;
    transition: transform 0.25s ease;
    -webkit-user-select: none;
    user-select: none;
    pointer-events: none;
  }

  /* 마우스 hover 시 활기차게 흔들기 */
  .mascot-button:hover .mascot {
    animation: wiggle 0.6s ease-in-out infinite;
  }

  /* 클릭하면 한 바퀴 회전 (다른 애니메이션보다 우선 적용) */
  .mascot-button .mascot.spin,
  .mascot-button:hover .mascot.spin {
    animation: spin 0.8s cubic-bezier(0.5, 0, 0.4, 1) 1;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-6px) rotate(2deg); }
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(-8deg); }
    50% { transform: rotate(8deg); }
  }

  @keyframes spin {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); }
  }

  /* 모션 줄이기 설정 존중 */
  @media (prefers-reduced-motion: reduce) {
    .mascot,
    .mascot-button:hover .mascot,
    .mascot-button .mascot.spin {
      animation: none;
    }
  }

  /* ─── Hero text ─── */
  .hero h1 {
    font-size: 44px;
    margin-bottom: 18px;
    letter-spacing: -1.2px;
  }
  .hero .subtitle {
    font-size: 18px;
    opacity: 0.7;
    margin-bottom: 36px;
  }

  /* ─── CTA buttons ─── */
  .cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .store-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: var(--ink);
    color: var(--paper) !important;
    font-weight: 700;
    border: 1.5px solid var(--ink);
    box-shadow: 4px 4px 0 var(--ink);
    transition:
      transform 0.1s ease,
      box-shadow 0.1s ease;
  }
  .store-button:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--ink);
    color: var(--paper) !important;
  }
  .store-button svg {
    flex-shrink: 0;
  }
  .cta-note {
    font-size: 13px;
    opacity: 0.5;
  }

  /* ─── Features ─── */
  .features {
    margin-top: 56px;
    padding: 28px 32px;
    border: 1.5px solid var(--ink);
    background: rgba(255, 255, 255, 0.3);
  }
  .features h2 {
    font-size: 20px;
    margin-bottom: 18px;
  }
  .feature-list {
    list-style: none;
    padding: 0 !important;
    margin: 0 !important;
  }
  .feature-list li {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(62, 58, 55, 0.12);
    font-size: 16px;
  }
  .feature-list li:last-child {
    border-bottom: none;
  }
  .feature-icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.2px solid rgba(62, 58, 55, 0.7);
    background: var(--paper);
    color: var(--ink);
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }
  .feature-list li:hover .feature-icon {
    background: var(--ink);
    color: var(--paper);
    transform: rotate(-4deg) scale(1.05);
  }
  .feature-text {
    flex: 1;
  }

  /* ─── Legal links ─── */
  .legal-links {
    margin-top: 48px;
  }
  .legal-links h2 {
    font-size: 18px;
    margin-bottom: 14px;
    opacity: 0.65;
  }
  .legal-list {
    list-style: none;
    padding: 0 !important;
    margin: 0 !important;
  }
  .legal-list li {
    padding: 4px 0;
  }
  .legal-list a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0;
    font-size: 15px;
    border-bottom: 1px solid rgba(62, 58, 55, 0.3);
    transition: gap 0.2s ease, color 0.2s ease;
  }
  .legal-list a:hover {
    gap: 14px;
    color: var(--accent);
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .mascot {
      width: 150px;
    }
    .hero h1 {
      font-size: 32px;
    }
    .hero .subtitle {
      font-size: 16px;
    }
    .features {
      padding: 24px 22px;
    }
    .feature-list li {
      gap: 12px;
    }
    .feature-icon {
      width: 34px;
      height: 34px;
    }
  }
</style>
