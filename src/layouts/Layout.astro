---
interface Props {
  title?: string;
  description?: string;
}

// .md 페이지는 frontmatter 로, .astro 페이지는 props 로 들어옴 — 둘 다 처리
const fm = (Astro.props as any).frontmatter ?? Astro.props;
const title: string = fm.title ?? '퍼필 — 나만의 독서 컬렉션';
const description: string =
  fm.description ?? '읽은 책을 차곡차곡 모으는 따뜻한 독서 기록 앱';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href={`${base}/perfil_mascot.png`} />
    <link rel="apple-touch-icon" href={`${base}/perfil_mascot.png`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href={`${base}/`} class="logo">
        <img
          src={`${base}/characters/essay_icon.webp`}
          alt=""
          class="logo-character"
          width="32"
          height="32"
          aria-hidden="true"
        />
        <span class="logo-text">Per<span class="accent">Fil</span></span>
      </a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <a href={`${base}/`} class="footer-brand">
          <img
            src={`${base}/characters/essay_icon.webp`}
            alt=""
            width="28"
            height="28"
            aria-hidden="true"
          />
          <span>Per<span class="accent">Fil</span></span>
        </a>

        <nav class="footer-links" aria-label="법적 고지 및 사이트 링크">
          <a href={`${base}/`}>홈</a>
          <a href={`${base}/terms`}>이용약관</a>
          <a href={`${base}/privacy`}>개인정보 처리방침</a>
        </nav>

        <div class="footer-tagline">읽은 책을 마음에 담아두는, 나만의 독서 컬렉션 앱.</div>
        <div class="copyright">© 2026 퍼필 (PerFil). All rights reserved.</div>
      </div>
    </footer>

    <style is:global>
      :root {
        --paper: #f4efe1;
        --paper-dim: #e9ddc7;
        --ink: #3e3a37;
        --accent: #b2422d;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background-color: var(--paper);
        color: var(--ink);
        font-family:
          'Pretendard',
          -apple-system,
          BlinkMacSystemFont,
          'Apple SD Gothic Neo',
          'Noto Sans KR',
          system-ui,
          sans-serif;
        font-size: 16px;
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: inherit;
        text-decoration: none;
        transition: color 0.15s ease;
      }
      a:hover {
        color: var(--accent);
      }

      h1,
      h2,
      h3,
      h4 {
        font-weight: 700;
        line-height: 1.3;
        letter-spacing: -0.5px;
      }

      /* ─── 사이트 헤더 ─── */
      .site-header {
        padding: 18px 32px;
        border-bottom: 1px solid rgba(62, 58, 55, 0.15);
      }
      .site-header .logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 22px;
        font-weight: 800;
        letter-spacing: -0.5px;
      }
      .site-header .logo-character {
        width: 32px;
        height: 32px;
        object-fit: contain;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .site-header .logo:hover .logo-character {
        transform: rotate(-12deg) scale(1.12);
      }
      .site-header .logo .accent {
        color: var(--accent);
      }

      /* ─── 메인 영역 ─── */
      main {
        flex: 1;
        width: 100%;
        max-width: 760px;
        margin: 0 auto;
        padding: 56px 24px 80px;
      }

      main h1 {
        font-size: 32px;
        margin-bottom: 12px;
      }
      main h2 {
        font-size: 19px;
        margin-top: 36px;
        margin-bottom: 12px;
      }
      main h3 {
        font-size: 16px;
        margin-top: 24px;
        margin-bottom: 8px;
      }
      main p,
      main ul,
      main ol,
      main table {
        margin-bottom: 16px;
      }
      main ul,
      main ol {
        padding-left: 22px;
      }
      main li {
        margin-bottom: 4px;
      }
      main strong {
        font-weight: 700;
      }
      main hr {
        border: none;
        border-top: 1px solid rgba(62, 58, 55, 0.2);
        margin: 24px 0;
      }
      main table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
      }
      main table th,
      main table td {
        border: 1px solid rgba(62, 58, 55, 0.2);
        padding: 10px 12px;
        text-align: left;
        vertical-align: top;
      }
      main table th {
        background: rgba(62, 58, 55, 0.05);
        font-weight: 700;
      }

      /* ─── 사이트 푸터 ─── */
      .site-footer {
        padding: 56px 24px 48px;
        border-top: 1px solid rgba(62, 58, 55, 0.15);
        background: rgba(62, 58, 55, 0.04);
        margin-top: 80px;
      }
      .footer-inner {
        max-width: 760px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        text-align: center;
      }
      .footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 22px;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: var(--ink);
        margin-bottom: 4px;
      }
      .footer-brand img {
        object-fit: contain;
      }
      .footer-brand .accent {
        color: var(--accent);
      }
      .footer-links {
        display: flex;
        gap: 22px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .footer-links a {
        font-size: 14px;
        font-weight: 600;
        padding: 6px 4px;
        border-bottom: 1px solid transparent;
        transition:
          color 0.18s ease,
          border-color 0.18s ease;
      }
      .footer-links a:hover {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }
      .footer-tagline {
        font-size: 14px;
        opacity: 0.6;
        line-height: 1.6;
        max-width: 360px;
        margin-top: 6px;
      }
      .copyright {
        font-size: 12px;
        opacity: 0.5;
        letter-spacing: 0.3px;
        margin-top: 4px;
      }

      @media (max-width: 600px) {
        .site-header {
          padding: 18px 20px;
        }
        main {
          padding: 36px 20px 60px;
        }
        main h1 {
          font-size: 26px;
        }
        main h2 {
          font-size: 17px;
        }
      }
    </style>
  </body>
</html>
