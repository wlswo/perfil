---
interface Props {
  title?: string;
  description?: string;
}

// .md 페이지는 frontmatter 로, .astro 페이지는 props 로 들어옴 — 둘 다 처리
const fm = (Astro.props as any).frontmatter ?? Astro.props;
const title: string = fm.title ?? '퍼필 — 나만의 독서 컬렉션';
const description: string =
  fm.description ?? '읽은 책을 차곡차곡 모으는 따뜻한 독서 기록 앱';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}/icon.png`} />
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}/`} class="logo">
          <img
            src={`${base}/icon.png`}
            alt=""
            class="logo-character"
            width="32"
            height="32"
            aria-hidden="true"
          />
          <span class="logo-text">perfil</span>
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <a href={`${base}/`} class="footer-brand">
          <img
            src={`${base}/icon.png`}
            alt=""
            width="28"
            height="28"
            aria-hidden="true"
          />
          <span>perfil</span>
        </a>

        <nav class="footer-links" aria-label="법적 고지 및 사이트 링크">
          <a href={`${base}/`}>홈</a>
          <a href={`${base}/terms`}>이용약관</a>
          <a href={`${base}/privacy`}>개인정보 처리방침</a>
        </nav>

        <div class="footer-tagline">읽은 책을 마음에 담아두는, 나만의 독서 컬렉션 앱.</div>
        <div class="copyright">© 2026 퍼필 (perfil). All rights reserved.</div>
      </div>
    </footer>

    <style is:global>
      :root {
        /* 토스 스타일 토큰 — perfil-frontend/src/styles/tokens.ts 와 일치 */
        --brand-50: #fff4ed;
        --brand-100: #ffe4d2;
        --brand-200: #ffc9a8;
        --brand-400: #ff8c4b;
        --brand-500: #ff6b2c; /* primary */
        --brand-600: #e5521a;
        --brand-700: #b2422d;

        --gray-0: #ffffff;
        --gray-50: #f9fafb;
        --gray-100: #f2f4f6;
        --gray-200: #e5e8eb;
        --gray-400: #b0b8c1;
        --gray-600: #4e5968;
        --gray-900: #191f28;

        --shadow-1: 0 1px 2px rgba(0, 0, 0, 0.04);
        --shadow-2: 0 4px 12px rgba(0, 0, 0, 0.06);
        --shadow-3: 0 8px 24px rgba(0, 0, 0, 0.08);
        --shadow-card-lg: 0 20px 60px rgba(25, 31, 40, 0.10);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background-color: var(--gray-0);
        color: var(--gray-900);
        font-family:
          'Pretendard Variable',
          'Pretendard',
          -apple-system,
          BlinkMacSystemFont,
          'Apple SD Gothic Neo',
          'Noto Sans KR',
          system-ui,
          sans-serif;
        font-size: 16px;
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: inherit;
        text-decoration: none;
        transition: color 0.15s ease;
      }
      a:hover {
        color: var(--brand-500);
      }

      h1,
      h2,
      h3,
      h4 {
        font-weight: 800;
        line-height: 1.25;
        letter-spacing: -0.04em;
        color: var(--gray-900);
      }

      /* ─── 사이트 헤더 (sticky, 흰 배경) ─── */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: saturate(180%) blur(12px);
        -webkit-backdrop-filter: saturate(180%) blur(12px);
        border-bottom: 1px solid var(--gray-100);
      }
      .header-inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 14px 24px;
      }
      .site-header .logo {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 19px;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: var(--gray-900);
      }
      .site-header .logo-character {
        width: 32px;
        height: 32px;
        object-fit: contain;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .site-header .logo:hover {
        color: var(--gray-900);
      }
      .site-header .logo:hover .logo-character {
        transform: rotate(-8deg) scale(1.08);
      }
      .site-header .logo-text {
        background: linear-gradient(135deg, var(--gray-900) 0%, var(--brand-600) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      /* ─── 메인 영역 ─── */
      main {
        flex: 1;
        width: 100%;
        max-width: 1080px;
        margin: 0 auto;
        padding: 40px 24px 80px;
      }

      /* 정책/약관 페이지 텍스트 스타일 (markdown 페이지용) */
      main h1 {
        font-size: 32px;
        margin-bottom: 12px;
      }
      main h2 {
        font-size: 19px;
        margin-top: 36px;
        margin-bottom: 12px;
      }
      main h3 {
        font-size: 16px;
        margin-top: 24px;
        margin-bottom: 8px;
      }
      main p,
      main ul,
      main ol,
      main table {
        margin-bottom: 16px;
      }
      main ul,
      main ol {
        padding-left: 22px;
      }
      main li {
        margin-bottom: 4px;
        color: var(--gray-600);
      }
      main strong {
        font-weight: 700;
        color: var(--gray-900);
      }
      main hr {
        border: none;
        border-top: 1px solid var(--gray-200);
        margin: 24px 0;
      }
      main table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
      }
      main table th,
      main table td {
        border: 1px solid var(--gray-200);
        padding: 10px 12px;
        text-align: left;
        vertical-align: top;
      }
      main table th {
        background: var(--gray-50);
        font-weight: 700;
      }

      /* ─── 사이트 푸터 ─── */
      .site-footer {
        margin-top: 80px;
        padding: 56px 24px 48px;
        background: var(--gray-50);
        border-top: 1px solid var(--gray-100);
      }
      .footer-inner {
        max-width: 1080px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        text-align: center;
      }
      .footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 18px;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: var(--gray-900);
        margin-bottom: 4px;
      }
      .footer-brand img {
        object-fit: contain;
      }
      .footer-brand span {
        background: linear-gradient(135deg, var(--gray-900) 0%, var(--brand-600) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .footer-links {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .footer-links a {
        font-size: 14px;
        font-weight: 600;
        color: var(--gray-600);
        padding: 8px 14px;
        border-radius: 999px;
        transition:
          color 0.18s ease,
          background-color 0.18s ease;
      }
      .footer-links a:hover {
        color: var(--brand-600);
        background: var(--brand-50);
      }
      .footer-tagline {
        font-size: 14px;
        color: var(--gray-600);
        line-height: 1.6;
        max-width: 360px;
        margin-top: 6px;
      }
      .copyright {
        font-size: 12px;
        color: var(--gray-400);
        letter-spacing: 0.3px;
        margin-top: 4px;
      }

      @media (max-width: 600px) {
        .header-inner {
          padding: 12px 20px;
        }
        main {
          padding: 28px 20px 60px;
        }
        main h1 {
          font-size: 26px;
        }
        main h2 {
          font-size: 17px;
        }
      }
    </style>
  </body>
</html>
